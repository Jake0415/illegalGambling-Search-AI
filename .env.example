# ──────────────────────────────────────
# Database
# ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/gambleguard
REDIS_URL=redis://localhost:6379

# ──────────────────────────────────────
# Authentication (NextAuth.js v5)
# ──────────────────────────────────────
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000
AUTH_TRUST_HOST=true

# ──────────────────────────────────────
# Storage (MinIO / S3)
# ──────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=evidence
S3_REGION=us-east-1

# ──────────────────────────────────────
# Claude AI API
# ──────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx

# ──────────────────────────────────────
# SMS Verification Services
# ──────────────────────────────────────
PVAPINS_API_KEY=
GRIZZLYSMS_API_KEY=
SMS_ACTIVATE_API_KEY=

# ──────────────────────────────────────
# CAPTCHA Solver
# ──────────────────────────────────────
CAPSOLVER_API_KEY=
TWOCAPTCHA_API_KEY=

# ──────────────────────────────────────
# Proxy
# ──────────────────────────────────────
PROXY_HOST=
PROXY_PORT=
PROXY_USERNAME=
PROXY_PASSWORD=

# ──────────────────────────────────────
# Google Custom Search (Detection)
# ──────────────────────────────────────
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# ──────────────────────────────────────
# Email SMTP
# ──────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_TO=

# ──────────────────────────────────────
# Slack API
# ──────────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_CHANNEL=
SLACK_BOT_USER_ID=
SLACK_TARGET_USER_ID=
SLACK_WEBHOOK_URL=

# ──────────────────────────────────────
# Notifications
# ──────────────────────────────────────

# ──────────────────────────────────────
# Application
# ──────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
